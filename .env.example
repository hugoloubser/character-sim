# ==========================================================================
# Character Creator — Environment Configuration
# ==========================================================================
# Copy this file to  local/.env  and fill in your values.
# The app loads local/.env automatically when APP_ENV=local (default).
# ==========================================================================

# Environment: "local" (default) | "prod"
APP_ENV=local

# LLM Provider Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, google
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Model Configuration
DEFAULT_MODEL=gpt-4-turbo-preview
FAST_MODEL=gpt-3.5-turbo

# Character Configuration
MAX_CHARACTER_MEMORY_TOKENS=4000
DIALOGUE_TEMPERATURE=0.8
CREATIVITY_WEIGHT=0.7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# Logging
LOG_LEVEL=INFO
